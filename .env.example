# ScamSense — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is gitignored.

# ============================================================
# AWS — API Gateway → Lambda → CloudWatch
# Region: ap-southeast-5 (Malaysia)
# ============================================================
AWS_RISK_API_URL=https://<your-api-id>.execute-api.ap-southeast-5.amazonaws.com/risk-event
AWS_REGION=ap-southeast-5

# ============================================================
# Alibaba Cloud — OSS (preferred path)
# Region: oss-ap-southeast-3 (Kuala Lumpur)
# ============================================================
ALIBABA_OSS_REGION=oss-ap-southeast-3
ALIBABA_OSS_BUCKET=scamsense-demo-risk-events
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=

# ============================================================
# Alibaba Cloud — Function Compute (optional alternative)
# Leave blank to use the OSS path instead.
# ============================================================
ALIBABA_FRAUD_API_URL=
